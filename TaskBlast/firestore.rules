rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdminByEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    function changingProtectedUserFields() {
      return request.resource.data.diff(resource.data).changedKeys().hasAny([
        "rocks",
        "allTimeRocks",
        "allTimeRocksArr",
        "rocksSpent",
        "sessionOverride",
        "sessionTimerOverride",
        "nextSessionSkip",
        "adminSessionSkip"
      ]);
    }

    match /admins/{adminEmail} {
      allow read: if isAdminByEmail();
      allow write: if false;
    }

    match /adminSessions/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /adminActions/{actionId} {
      allow read: if isAdminByEmail();
      allow write: if false;
    }

    match /shopItems/{itemId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdminByEmail();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminByEmail();
      allow create: if isOwner(userId);
      allow update: if isAdminByEmail() || (isOwner(userId) && !changingProtectedUserFields());
      allow delete: if isAdminByEmail();

      match /children/{childId} {
        allow read, write: if isOwner(userId) || isAdminByEmail();
      }

      match /tasks/{taskId} {
        allow read, write: if isOwner(userId) || isAdminByEmail();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
